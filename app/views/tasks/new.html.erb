<h1>New Tasks</h1>

<form action="/tasks" class="form-group">
  <div class="form-group">
    <label for="title" name="title" class="control-label"><span>Title</span></label><br>
    <div class="col-sm-10" >
       <input type="text" name="<%= @task.title %>" class="form-control">
    </div>
  </div>

  <div class="form-group">
    <label for="details" name="details" class="control-label">Details</label><br>
    <div class="col-sm-10">
      <input type="text" name="details" class="form-control">
    </div>
  </div>

<br>
  <div class="form-group">
    <div class="btn btn-primary">
      <button type="submit" value="Create Task">Create Task</button>
    </div>
  </div>
</form>
